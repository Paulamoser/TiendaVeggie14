<odoo>
    <record id="product_template_form_webdescription" model="ir.ui.view">
        <field name="name">product.template.product.websitedesc.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
           <!--<xpath expr="//field[@name='label_line_ids']" position="after">-->
               <xpath expr="//field[@name='description']" position="after">
                   <group string="Descripción Web">
                   <field name="website_description" nolabel="1"/>
                   </group>
            </xpath>
        </field>
    </record>
</odoo>