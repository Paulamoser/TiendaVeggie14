<odoo>
  <data>
    <!-- explicit list view definition -->


      <record id="statistics_sale_grid" model="ir.ui.view">
        <field name="name">statistics_sale_grid</field>
        <field name="model">report.statistics.sale</field>
        <field name="arch" type="xml">
            <grid js_class="stock_enterprise_report_grid"
                string="Quantity"
                adjustment="object"
                adjust_name="adjust_grid"
                hide_line_total="1"
                hide_column_total="1">
                <field name="default_code" type="row"/>
               <!-- <field name="state" type="row"/>-->
                <field name="nro_week" type="col">
                    <range name="week" string="Week" span="week" step="day"/>
                    <range name="month" string="Month" span="month" step="day"/>
                </field>
                <field name="quantity" type="measure"/>
            </grid>
        </field>
    </record>
    <record id="action_statistics_sales" model="ir.actions.act_window">
        <field name="name">Informe Estadisticas de Ventas</field>
        <field name="res_model">report.statistics.sale</field>
        <field name="view_mode">grid</field>
        <field name="context">{}</field>
    </record>

  </data>
</odoo>