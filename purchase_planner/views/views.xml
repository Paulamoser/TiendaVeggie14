<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <record model="ir.ui.view" id="purchase_planner_form">
      <field name="name">purchase.planner.form</field>
      <field name="model">purchase_planner.purchase_planner</field>
      <field name="arch" type="xml">
        <group>
          <field name="fecha" readonly="1"/>
          <field name="partner_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'supplier'}" />
        </group>
        <notebook>
           <page string="Product Lines" name="product_lines">
             <field
                     name="purchase_planner_line"
                     widget="section_and_note_one2many"
                                mode="tree,kanban"
             >
               <form>
                 <field name="product_id" readonly="True"/>
                 <field name="product_name" readonly="True"/>
                 <field name="today_stock_am " readonly="True"/>
                 <field name="today_in " readonly="True"/>
                 <field name="today_out " readonly="True"/>
                 <field name="today_stock_pm " readonly="True"/>
                 <field name="today_purchase " readonly="True"/>
               </form>
             </field>
           </page>
        </notebook>
      </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="purchase_planner.action_window">
      <field name="name">purchase_planner window</field>
      <field name="res_model">purchase_planner.purchase_planner</field>
      <field name="view_mode">form</field>
      <!--tree-->
    </record>

    <menuitem name="purchase_planner" id="purchase_planner.menu_root"/>
</data>

</odoo>